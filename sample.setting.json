{
  "projectName": "MDKOSS-Demo",
  "cycleMs": 20,
  "drivers": [
    {
      "id": "drv-main",
      "type": "sim",
      "enabled": true,
      "parameters": {
        "ip": "127.0.0.1",
        "port": "5000"
      }
    }
  ],
  "tasks": [
    {
      "name": "task-operation",
      "type": "operation",
      "intervalMs": 200,
      "parameters": {}
    },
    {
      "name": "task-cycle",
      "type": "cycle",
      "intervalMs": 1000,
      "parameters": {}
    },
    {
      "name": "poll-main",
      "type": "pollDriver",
      "driverId": "drv-main",
      "intervalMs": 500,
      "parameters": {}
    }
  ],
  "vars": {
    "machine.mode": "AUTO",
    "machine.ready": true
  }
}
